@dataclass
class CDEGConfig:
    # Input feature dimensions. If use_bert=True, text dim is overwritten by BERT hidden size.
    feature_dims: Tuple[int, int, int] = (768, 74, 35)
    d_model: int = 128
    dropout: float = 0.1

    # Text encoder.
    use_bert: bool = True
    use_finetune: bool = True
    transformers: str = "bert"  # "bert" or "roberta"
    pretrained: str = "bert-base-uncased"

    # Modality encoder.
    n_layers: int = 2
    n_heads: int = 4
    ff_mult: int = 4

    # Evidence tokenizer.
    k_max: int = 6
    topk_attn: int = 0  # 0 means no hard top-k pruning.
    evidence_gate_tau: float = 0.67
    hard_evidence_gate: bool = False
    gate_threshold: float = 0.5

    # Signed graph.
    graph_layers: int = 2
    graph_cross_only: bool = False
    graph_temperature: float = 0.5
    lambda_time: float = 0.5
    lambda_polarity: float = 1.0
    lambda_uncertainty: float = 0.4

    # Counterfactual target construction.
    compute_node_cf: bool = True
    edge_cf_mode: str = "proxy"  # "proxy" keeps training efficient.

    # Loss weights.
    w_main: float = 1.0
    w_ord: float = 0.2
    w_uni: float = 0.15
    w_disentangle: float = 0.02
    w_sparse: float = 0.005
    w_graph: float = 0.02
    w_cf_node: float = 0.05
    w_cf_edge: float = 0.02
    w_unc: float = 0.005


# -----------------------------------------------------------------------------
# Utility functions
# -----------------------------------------------------------------------------


def build_sequence_mask(x: torch.Tensor, mask: Optional[torch.Tensor] = None) -> torch.Tensor:
    """Build boolean mask [B, T], True means valid."""
    if mask is not None:
        seq_mask = mask.bool()
    elif x.dim() == 3:
        seq_mask = (x.abs().sum(dim=-1) > 0).bool()
    else:
        seq_mask = (x > 0).bool()

    if seq_mask.dim() == 2:
        empty_rows = ~seq_mask.any(dim=1)
        if empty_rows.any():
            seq_mask = seq_mask.clone()
            seq_mask[empty_rows, 0] = True
    return seq_mask


def masked_mean(x: torch.Tensor, mask: torch.Tensor) -> torch.Tensor:
    """Masked mean pooling for [B, T, D]."""
    w = mask.unsqueeze(-1).to(x.dtype)
    return (x * w).sum(dim=1) / w.sum(dim=1).clamp_min(1e-6)


def masked_softmax(logits: torch.Tensor, mask: torch.Tensor, dim: int = -1) -> torch.Tensor:
    logits = logits.masked_fill(~mask.bool(), -1e4)
    probs = F.softmax(logits, dim=dim)
    probs = probs * mask.to(probs.dtype)
    return probs / probs.sum(dim=dim, keepdim=True).clamp_min(1e-6)


def gumbel_sigmoid(
    logits: torch.Tensor,
    tau: float = 1.0,
    hard: bool = False,
    training: bool = True,
    threshold: float = 0.5,
) -> torch.Tensor:
    """Differentiable binary gate using Binary Concrete / Gumbel-Sigmoid."""
    if training:
        eps = 1e-10
        u = torch.rand_like(logits).clamp_(eps, 1.0 - eps)
        g = torch.log(u) - torch.log(1.0 - u)
        y = torch.sigmoid((logits + g) / max(tau, 1e-6))
        if hard:
            y_hard = (y > threshold).to(y.dtype)
            y = y_hard.detach() - y.detach() + y
        return y
    return (torch.sigmoid(logits) > threshold).to(logits.dtype) if hard else torch.sigmoid(logits)


def entropy(probs: torch.Tensor, dim: int = -1) -> torch.Tensor:
    return -(probs.clamp_min(1e-8) * probs.clamp_min(1e-8).log()).sum(dim=dim)


def offdiag_mean_square(sim: torch.Tensor) -> torch.Tensor:
    """Mean squared off-diagonal similarity for slot diversity."""
    k = sim.size(-1)
    eye = torch.eye(k, device=sim.device, dtype=sim.dtype).unsqueeze(0)
    off = 1.0 - eye
    return ((sim * off) ** 2).sum() / off.sum().clamp_min(1.0) / sim.size(0)


def normalize_with_mask(x: torch.Tensor, mask: torch.Tensor, dim: int = -1) -> torch.Tensor:
    x = x * mask.to(x.dtype)
    return x / x.sum(dim=dim, keepdim=True).clamp_min(1e-6)


def masked_kl_div(pred_prob: torch.Tensor, target_prob: torch.Tensor, mask: torch.Tensor) -> torch.Tensor:
    """KL(target || pred) with mask. Inputs are probabilities."""
    mask = mask.to(pred_prob.dtype)
    pred = normalize_with_mask(pred_prob.clamp_min(1e-8), mask, dim=-1)
    target = normalize_with_mask(target_prob.clamp_min(1e-8), mask, dim=-1).detach()
    kl = target * (target.clamp_min(1e-8).log() - pred.clamp_min(1e-8).log())
    return (kl * mask).sum(dim=-1).mean()


