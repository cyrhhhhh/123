TRANSFORMERS_MAP = {
    "bert": (BertTokenizer, BertModel),
    "roberta": (RobertaTokenizer, RobertaModel),
}


class BertTextEncoder(nn.Module):
    """BERT/RoBERTa text encoder returning token-level features [B, Lt, H]."""

    def __init__(self, use_finetune: bool = True, transformers: str = "bert", pretrained: str = "bert-base-uncased"):
        super().__init__()
        if BertModel is None:
            raise ImportError("transformers is required when use_bert=True. Install with `pip install transformers`.")
        tokenizer_class, model_class = TRANSFORMERS_MAP[transformers]
        self.tokenizer = tokenizer_class.from_pretrained(pretrained)
        self.model = model_class.from_pretrained(pretrained)
        self.use_finetune = use_finetune
        self.transformers = transformers
        self.hidden_size = self.model.config.hidden_size

    def forward(self, text: torch.Tensor) -> torch.Tensor:
        input_ids = text[:, 0, :].long()
        input_mask = text[:, 1, :].long()
        segment_ids = text[:, 2, :].long()

        kwargs = {"input_ids": input_ids, "attention_mask": input_mask}
        if self.transformers == "bert":
            kwargs["token_type_ids"] = segment_ids

        if self.use_finetune:
            return self.model(**kwargs).last_hidden_state
        with torch.no_grad():
            return self.model(**kwargs).last_hidden_state


class MultiScaleTemporalStem(nn.Module):
    """Parallel multi-scale Conv1d stem with residual projection."""

    def __init__(self, d_in: int, d_model: int, kernels: Sequence[int] = (1, 3, 5), dropout: float = 0.1):
        super().__init__()
        branch_dim = d_model
        self.branches = nn.ModuleList([
            nn.Sequential(
                nn.Conv1d(d_in, branch_dim, kernel_size=k, padding=k // 2, bias=False),
                nn.GELU(),
                nn.Dropout(dropout),
            )
            for k in kernels
        ])
        self.out_proj = nn.Linear(branch_dim * len(kernels), d_model)
        self.res_proj = nn.Linear(d_in, d_model) if d_in != d_model else nn.Identity()
        self.norm = nn.LayerNorm(d_model)
        self.drop = nn.Dropout(dropout)

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        residual = self.res_proj(x)
        x_t = x.transpose(1, 2)
        feats = [branch(x_t).transpose(1, 2) for branch in self.branches]
        h = self.out_proj(torch.cat(feats, dim=-1))
        return self.norm(self.drop(h) + residual)


class MaskedTransformerEncoder(nn.Module):
    """Stacked mask-aware Transformer encoder."""

    def __init__(self, d_model: int, n_layers: int = 2, n_heads: int = 4, ff_mult: int = 4, dropout: float = 0.1):
        super().__init__()
        self.layers = nn.ModuleList([
            nn.TransformerEncoderLayer(
                d_model=d_model,
                nhead=n_heads,
                dim_feedforward=d_model * ff_mult,
                dropout=dropout,
                activation="gelu",
                batch_first=True,
                norm_first=True,
            )
            for _ in range(n_layers)
        ])
        self.norm = nn.LayerNorm(d_model)

    def forward(self, x: torch.Tensor, mask: Optional[torch.Tensor]) -> torch.Tensor:
        if mask is not None:
            x = x * mask.unsqueeze(-1).to(x.dtype)
        key_padding_mask = ~mask.bool() if mask is not None else None
        for layer in self.layers:
            x = layer(x, src_key_padding_mask=key_padding_mask)
            if mask is not None:
                x = x * mask.unsqueeze(-1).to(x.dtype)
        x = self.norm(x)
        if mask is not None:
            x = x * mask.unsqueeze(-1).to(x.dtype)
        return x


# -----------------------------------------------------------------------------
# Innovation 1: Dynamic Causal Disentangled Evidence Tokenizer
# -----------------------------------------------------------------------------


class DynamicCausalEvidenceTokenizer(nn.Module):
    """Dynamic sparse evidence tokenizer with tri-factor disentanglement.

    Produces K_max candidate evidence tokens and a differentiable gate for each token.
    Downstream graph reasoning uses the sentiment evidence component by default.
    """

    def __init__(
        self,
        d_model: int,
        k_max: int = 6,
        dropout: float = 0.1,
        topk_attn: int = 0,
        gate_tau: float = 0.67,
        hard_gate: bool = False,
        gate_threshold: float = 0.5,
    ):
        super().__init__()
        self.k_max = k_max
        self.topk_attn = topk_attn
        self.gate_tau = gate_tau
        self.hard_gate = hard_gate
        self.gate_threshold = gate_threshold

        self.slot_queries = nn.Parameter(torch.randn(1, k_max, d_model) * 0.02)
        self.ctx_proj = nn.Sequential(
            nn.Linear(d_model, d_model),
            nn.GELU(),
            nn.Linear(d_model, d_model),
        )
        self.query_gate = nn.Sequential(
            nn.Linear(d_model * 2, d_model),
            nn.GELU(),
            nn.Linear(d_model, d_model),
            nn.Sigmoid(),
        )
        self.query_norm = nn.LayerNorm(d_model)
        self.key_norm = nn.LayerNorm(d_model)
        self.value_proj = nn.Linear(d_model, d_model)

        # Dynamic evidence existence gate.
        self.slot_gate_head = nn.Sequential(
            nn.LayerNorm(d_model * 2),
            nn.Linear(d_model * 2, d_model),
            nn.GELU(),
            nn.Dropout(dropout),
            nn.Linear(d_model, 1),
        )

        # Evidence attributes.
        self.polarity_head = nn.Sequential(nn.Linear(d_model, d_model), nn.GELU(), nn.Linear(d_model, 1), nn.Tanh())
        self.strength_head = nn.Sequential(nn.Linear(d_model, d_model), nn.GELU(), nn.Linear(d_model, 1), nn.Softplus())
        self.uncertainty_head = nn.Sequential(nn.Linear(d_model, d_model), nn.GELU(), nn.Linear(d_model, 1), nn.Softplus())
        self.position_head = nn.Sequential(nn.Linear(d_model, d_model), nn.GELU(), nn.Linear(d_model, 1), nn.Sigmoid())

        # Tri-factor disentanglement.
        def projector() -> nn.Sequential:
            return nn.Sequential(
                nn.LayerNorm(d_model),
                nn.Linear(d_model, d_model),
                nn.GELU(),
                nn.Dropout(dropout),
                nn.Linear(d_model, d_model),
            )

        self.sentiment_proj = projector()
        self.private_proj = projector()
        self.noise_proj = projector()
        self.factor_gate = nn.Sequential(
            nn.LayerNorm(d_model),
            nn.Linear(d_model, d_model),
            nn.GELU(),
            nn.Dropout(dropout),
            nn.Linear(d_model, 3),
        )
        self.factor_norm = nn.LayerNorm(d_model)
        self.drop = nn.Dropout(dropout)

    def _sparse_attention(self, scores: torch.Tensor, mask: torch.Tensor) -> torch.Tensor:
        # scores: [B, K, T], mask: [B, T]
        scores = scores.masked_fill(~mask.unsqueeze(1).bool(), -1e4)
        if self.topk_attn is not None and self.topk_attn > 0 and self.topk_attn < scores.size(-1):
            vals, idx = scores.topk(self.topk_attn, dim=-1)
            sparse_scores = torch.full_like(scores, -1e4)
            sparse_scores.scatter_(-1, idx, vals)
            scores = sparse_scores
        attn = F.softmax(scores, dim=-1)
        attn = attn * mask.unsqueeze(1).to(attn.dtype)
        return attn / attn.sum(dim=-1, keepdim=True).clamp_min(1e-6)

    def forward(self, x: torch.Tensor, mask: Optional[torch.Tensor] = None, modality_id: int = 0) -> Dict[str, torch.Tensor]:
        B, T, D = x.shape
        if mask is None:
            mask = torch.ones(B, T, dtype=torch.bool, device=x.device)

        global_ctx = masked_mean(x, mask)
        base_q = self.slot_queries.expand(B, -1, -1)
        ctx_q = self.ctx_proj(global_ctx).unsqueeze(1).expand(-1, self.k_max, -1)
        q_gate = self.query_gate(torch.cat([base_q, ctx_q], dim=-1))
        q = self.query_norm(base_q + q_gate * ctx_q)

        # Dynamic token existence gate.
        slot_gate_logits = self.slot_gate_head(torch.cat([q, ctx_q], dim=-1)).squeeze(-1)
        slot_gate_prob = torch.sigmoid(slot_gate_logits)
        slot_gate = gumbel_sigmoid(
            slot_gate_logits,
            tau=self.gate_tau,
            hard=self.hard_gate,
            training=self.training,
            threshold=self.gate_threshold,
        )

        k = self.key_norm(x)
        scores = torch.matmul(q, k.transpose(1, 2)) / math.sqrt(D)
        attn = self._sparse_attention(scores, mask)

        raw_evidence = self.drop(torch.matmul(attn, self.value_proj(x)))  # [B, K, D]

        polarity = self.polarity_head(raw_evidence).squeeze(-1)
        strength = self.strength_head(raw_evidence).squeeze(-1)
        uncertainty = self.uncertainty_head(raw_evidence).squeeze(-1)

        pos_grid = torch.linspace(0.0, 1.0, T, device=x.device, dtype=x.dtype).view(1, 1, T)
        attn_position = (attn * pos_grid).sum(dim=-1)
        learned_position = self.position_head(raw_evidence).squeeze(-1)
        tau = 0.5 * attn_position + 0.5 * learned_position

        # Tri-factor evidence disentanglement.
        z_sent = self.factor_norm(self.sentiment_proj(raw_evidence))
        z_priv = self.factor_norm(self.private_proj(raw_evidence))
        z_noise = self.factor_norm(self.noise_proj(raw_evidence))
        factor_gate = F.softmax(self.factor_gate(raw_evidence), dim=-1)
        g_sent, g_priv, g_noise = factor_gate[..., 0], factor_gate[..., 1], factor_gate[..., 2]

        reconstructed = (
            g_sent.unsqueeze(-1) * z_sent
            + g_priv.unsqueeze(-1) * z_priv
            + g_noise.unsqueeze(-1) * z_noise
        )

        # Reliability combines strength, uncertainty, evidence existence, and sentiment purity.
        reliability = (
            strength
            - uncertainty
            + torch.log(slot_gate_prob.clamp_min(1e-6))
            + torch.log(g_sent.clamp_min(1e-6))
            - 0.5 * torch.log(g_noise.clamp_min(1e-6))
        )
        slot_weight = F.softmax(reliability, dim=-1)

        sent_norm = F.normalize(z_sent, dim=-1, eps=1e-6)
        slot_sim = torch.matmul(sent_norm, sent_norm.transpose(1, 2))

        modality_ids = torch.full((B, self.k_max), int(modality_id), device=x.device, dtype=torch.long)

        return {
            "evidence": z_sent,
            "raw_evidence": raw_evidence,
            "sentiment_evidence": z_sent,
            "private_evidence": z_priv,
            "noise_evidence": z_noise,
            "reconstructed_evidence": reconstructed,
            "factor_gate": factor_gate,
            "slot_gate": slot_gate,
            "slot_gate_prob": slot_gate_prob,
            "slot_gate_logits": slot_gate_logits,
            "slot_weight": slot_weight,
            "polarity": polarity,
            "strength": strength,
            "uncertainty": uncertainty,
            "reliability": reliability,
            "tau": tau,
            "attn": attn,
            "slot_sim": slot_sim,
            "modality_ids": modality_ids,
        }


# -----------------------------------------------------------------------------
# Innovation 2: Signed Counterfactual Evidence Graph
# -----------------------------------------------------------------------------


class SignedEvidenceGraphBuilder(nn.Module):
    """Build a signed evidence graph over sentiment evidence tokens.

    Edge roles:
    - 0: consensus
    - 1: conflict
    - 2: compensation / residual
    """

    def __init__(
        self,
        d_model: int,
        temperature: float = 0.5,
        cross_only: bool = False,
        lambda_time: float = 0.5,
        lambda_polarity: float = 1.0,
        lambda_uncertainty: float = 0.4,
    ):
        super().__init__()
        self.temperature = temperature
        self.cross_only = cross_only
        self.lambda_time = lambda_time
        self.lambda_polarity = lambda_polarity
        self.lambda_uncertainty = lambda_uncertainty

        self.edge_mlp = nn.Sequential(
            nn.Linear(d_model * 2 + 6, d_model),
            nn.GELU(),
            nn.Linear(d_model, 3),
        )

    @staticmethod
    def _concat_ev(text_ev: Dict[str, torch.Tensor], audio_ev: Dict[str, torch.Tensor], video_ev: Dict[str, torch.Tensor]):
        nodes = torch.cat([text_ev["sentiment_evidence"], audio_ev["sentiment_evidence"], video_ev["sentiment_evidence"]], dim=1)
        gates = torch.cat([text_ev["slot_gate_prob"], audio_ev["slot_gate_prob"], video_ev["slot_gate_prob"]], dim=1)
        polarity = torch.cat([text_ev["polarity"], audio_ev["polarity"], video_ev["polarity"]], dim=1)
        strength = torch.cat([text_ev["strength"], audio_ev["strength"], video_ev["strength"]], dim=1)
        uncertainty = torch.cat([text_ev["uncertainty"], audio_ev["uncertainty"], video_ev["uncertainty"]], dim=1)
        tau = torch.cat([text_ev["tau"], audio_ev["tau"], video_ev["tau"]], dim=1)
        modality_ids = torch.cat([text_ev["modality_ids"], audio_ev["modality_ids"], video_ev["modality_ids"]], dim=1)
        return nodes, gates, polarity, strength, uncertainty, tau, modality_ids

    def forward(self, text_ev: Dict[str, torch.Tensor], audio_ev: Dict[str, torch.Tensor], video_ev: Dict[str, torch.Tensor]) -> Dict[str, torch.Tensor]:
        nodes, gates, polarity, strength, uncertainty, tau, modality_ids = self._concat_ev(text_ev, audio_ev, video_ev)
        B, N, D = nodes.shape

        node_norm = F.normalize(nodes, dim=-1, eps=1e-6)
        sim = torch.matmul(node_norm, node_norm.transpose(1, 2))

        pol_i = polarity.unsqueeze(2)
        pol_j = polarity.unsqueeze(1)
        str_i = strength.unsqueeze(2)
        str_j = strength.unsqueeze(1)
        unc_i = uncertainty.unsqueeze(2)
        unc_j = uncertainty.unsqueeze(1)
        tau_i = tau.unsqueeze(2)
        tau_j = tau.unsqueeze(1)

        polar_gap = (pol_i - pol_j).abs()
        opposite = F.relu(-(pol_i * pol_j))
        same = F.relu(pol_i * pol_j)
        strength_pair = 0.5 * (str_i + str_j)
        unc_pair = 0.5 * (unc_i + unc_j)
        time_dist = (tau_i - tau_j).abs()

        mod_i = modality_ids.unsqueeze(2)
        mod_j = modality_ids.unsqueeze(1)
        cross_mod = (mod_i != mod_j)

        eye = torch.eye(N, device=nodes.device, dtype=torch.bool).unsqueeze(0)
        node_pair = gates.unsqueeze(2) * gates.unsqueeze(1)
        edge_mask = (~eye).to(nodes.dtype) * node_pair
        if self.cross_only:
            edge_mask = edge_mask * cross_mod.to(edge_mask.dtype)

        # Analytic role priors.
        base = sim + 0.15 * strength_pair - self.lambda_time * time_dist - self.lambda_uncertainty * unc_pair
        cons_prior = base + self.lambda_polarity * same - self.lambda_polarity * polar_gap
        conf_prior = base + self.lambda_polarity * opposite + 0.3 * polar_gap
        comp_prior = -sim.abs() + 0.2 * strength_pair + 0.4 * unc_pair - 0.2 * time_dist
        analytic_logits = torch.stack([cons_prior, conf_prior, comp_prior], dim=-1)

        # Learned correction.
        hi = nodes.unsqueeze(2).expand(-1, -1, N, -1)
        hj = nodes.unsqueeze(1).expand(-1, N, -1, -1)
        scalar_feats = torch.stack([sim, polar_gap, opposite, strength_pair, unc_pair, time_dist], dim=-1)
        learned_logits = self.edge_mlp(torch.cat([hi, hj, scalar_feats], dim=-1))

        edge_logits = analytic_logits + learned_logits
        role_prob = F.softmax(edge_logits / max(self.temperature, 1e-6), dim=-1)
        role_prob = role_prob * edge_mask.unsqueeze(-1)

        # Row-normalized adjacency for message passing.
        A = role_prob / role_prob.sum(dim=2, keepdim=True).clamp_min(1e-6)

        edge_importance = role_prob.sum(dim=-1)
        edge_importance = edge_importance / edge_importance.sum(dim=(1, 2), keepdim=True).clamp_min(1e-6)

        # Self-supervised pseudo edge type for a light graph-structure regularizer.
        # 0: same polarity and semantically aligned; 1: opposite polarity but semantically aligned; 2: weak/uncertain.
        pseudo_scores = torch.stack([
            sim.detach() + same.detach() - polar_gap.detach(),
            sim.detach() + opposite.detach() + polar_gap.detach(),
            -sim.detach().abs() + unc_pair.detach(),
        ], dim=-1)
        pseudo_target = pseudo_scores.argmax(dim=-1)

        return {
            "nodes": nodes,
            "node_gate": gates,
            "polarity": polarity,
            "strength": strength,
            "uncertainty": uncertainty,
            "tau": tau,
            "modality_ids": modality_ids,
            "sim": sim,
            "edge_mask": edge_mask,
            "edge_logits": edge_logits,
            "edge_role_prob": role_prob,
            "adjacency": A,
            "edge_importance": edge_importance,
            "edge_pseudo_target": pseudo_target,
        }


class SignedEvidenceGraphReasoner(nn.Module):
    """Signed message passing over consensus/conflict/compensation edges."""

    def __init__(self, d_model: int, n_layers: int = 2, dropout: float = 0.1):
        super().__init__()
        self.d_model = d_model
        self.n_layers = n_layers
        self.pos_proj = nn.ModuleList([nn.Linear(d_model, d_model) for _ in range(n_layers)])
        self.neg_proj = nn.ModuleList([nn.Linear(d_model, d_model) for _ in range(n_layers)])
        self.comp_proj = nn.ModuleList([nn.Linear(d_model, d_model) for _ in range(n_layers)])
        self.update = nn.ModuleList([
            nn.Sequential(
                nn.Linear(d_model * 4, d_model),
                nn.GELU(),
                nn.Dropout(dropout),
                nn.Linear(d_model, d_model),
            )
            for _ in range(n_layers)
        ])
        self.norms = nn.ModuleList([nn.LayerNorm(d_model) for _ in range(n_layers)])
        self.node_score = nn.Sequential(
            nn.LayerNorm(d_model),
            nn.Linear(d_model, d_model // 2),
            nn.GELU(),
            nn.Linear(d_model // 2, 1),
        )
        self.graph_fuse = nn.Sequential(
            nn.Linear(d_model * 3, d_model),
            nn.LayerNorm(d_model),
            nn.GELU(),
            nn.Dropout(dropout),
            nn.Linear(d_model, d_model),
            nn.LayerNorm(d_model),
        )

    def message_passing(self, h: torch.Tensor, adjacency: torch.Tensor) -> torch.Tensor:
        # adjacency: [B, N, N, 3]. A[i,j,r] sends message from j to i under role r.
        for layer in range(self.n_layers):
            A_pos = adjacency[..., 0]
            A_neg = adjacency[..., 1]
            A_comp = adjacency[..., 2]

            msg_pos = torch.matmul(A_pos, self.pos_proj[layer](h))
            msg_neg = torch.matmul(A_neg, self.neg_proj[layer](h))
            msg_comp = torch.matmul(A_comp, self.comp_proj[layer](h))

            upd = self.update[layer](torch.cat([h, msg_pos, msg_neg, msg_comp], dim=-1))
            h = self.norms[layer](h + upd)
        return h

    def pool_graph(
        self,
        h: torch.Tensor,
        edge_role_prob: torch.Tensor,
        node_gate: torch.Tensor,
    ) -> Tuple[torch.Tensor, Dict[str, torch.Tensor]]:
        # Role-specific node energy: outgoing + incoming role mass.
        role_energy = edge_role_prob.sum(dim=2) + edge_role_prob.sum(dim=1)  # [B, N, 3]
        role_weight = role_energy * node_gate.unsqueeze(-1)
        role_weight = role_weight / role_weight.sum(dim=1, keepdim=True).clamp_min(1e-6)

        z_cons = (role_weight[..., 0:1] * h).sum(dim=1)
        z_conf = (role_weight[..., 1:2] * h).sum(dim=1)
        z_comp = (role_weight[..., 2:3] * h).sum(dim=1)
        graph_repr = self.graph_fuse(torch.cat([z_cons, z_conf, z_comp], dim=-1))

        node_logits = self.node_score(h).squeeze(-1) + torch.log(node_gate.clamp_min(1e-6))
        node_importance = F.softmax(node_logits, dim=-1)
        node_importance = node_importance * node_gate
        node_importance = node_importance / node_importance.sum(dim=-1, keepdim=True).clamp_min(1e-6)

        return graph_repr, {
            "z_consensus": z_cons,
            "z_conflict": z_conf,
            "z_compensation": z_comp,
            "role_node_weight": role_weight,
            "node_importance": node_importance,
        }

    def forward(self, graph: Dict[str, torch.Tensor]) -> Dict[str, torch.Tensor]:
        h0 = graph["nodes"]
        h = self.message_passing(h0, graph["adjacency"])
        graph_repr, pooled = self.pool_graph(h, graph["edge_role_prob"], graph["node_gate"])

        # Efficient edge counterfactual proxy: message magnitude carried by each edge.
        # This acts as a differentiable target proxy for edge-level contribution.
        sender = h.unsqueeze(1)  # [B, 1, N, D]
        receiver = h.unsqueeze(2)  # [B, N, 1, D]
        edge_msg = graph["edge_role_prob"].sum(dim=-1) * (sender - receiver).norm(dim=-1)
        edge_cf_target = edge_msg.detach()
        edge_cf_target = edge_cf_target / edge_cf_target.sum(dim=(1, 2), keepdim=True).clamp_min(1e-6)

        return {
            **graph,
            **pooled,
            "node_hidden": h,
            "graph_repr": graph_repr,
            "edge_cf_target": edge_cf_target,
        }


