class CDEG_MSA(nn.Module):
    """Counterfactual Disentangled Evidence Graph for MSA."""

    def __init__(self, cfg: CDEGConfig):
        super().__init__()
        self.cfg = cfg
        d_t, d_a, d_v = cfg.feature_dims

        self.use_bert = cfg.use_bert
        if self.use_bert:
            self.bert = BertTextEncoder(
                use_finetune=cfg.use_finetune,
                transformers=cfg.transformers,
                pretrained=cfg.pretrained,
            )
            d_t = self.bert.hidden_size

        self.stem_t = MultiScaleTemporalStem(d_t, cfg.d_model, dropout=cfg.dropout)
        self.stem_a = MultiScaleTemporalStem(d_a, cfg.d_model, dropout=cfg.dropout)
        self.stem_v = MultiScaleTemporalStem(d_v, cfg.d_model, dropout=cfg.dropout)

        self.mod_embed = nn.Parameter(torch.randn(3, 1, cfg.d_model) * 0.02)
        self.shared_encoder = MaskedTransformerEncoder(
            d_model=cfg.d_model,
            n_layers=cfg.n_layers,
            n_heads=cfg.n_heads,
            ff_mult=cfg.ff_mult,
            dropout=cfg.dropout,
        )
        self.adapter_t = nn.Sequential(nn.LayerNorm(cfg.d_model), nn.Linear(cfg.d_model, cfg.d_model), nn.GELU())
        self.adapter_a = nn.Sequential(nn.LayerNorm(cfg.d_model), nn.Linear(cfg.d_model, cfg.d_model), nn.GELU())
        self.adapter_v = nn.Sequential(nn.LayerNorm(cfg.d_model), nn.Linear(cfg.d_model, cfg.d_model), nn.GELU())

        # Use separate tokenizers so each modality can learn its own evidence patterns.
        tok_kwargs = dict(
            d_model=cfg.d_model,
            k_max=cfg.k_max,
            dropout=cfg.dropout,
            topk_attn=cfg.topk_attn,
            gate_tau=cfg.evidence_gate_tau,
            hard_gate=cfg.hard_evidence_gate,
            gate_threshold=cfg.gate_threshold,
        )
        self.evidence_t = DynamicCausalEvidenceTokenizer(**tok_kwargs)
        self.evidence_a = DynamicCausalEvidenceTokenizer(**tok_kwargs)
        self.evidence_v = DynamicCausalEvidenceTokenizer(**tok_kwargs)

        self.graph_builder = SignedEvidenceGraphBuilder(
            d_model=cfg.d_model,
            temperature=cfg.graph_temperature,
            cross_only=cfg.graph_cross_only,
            lambda_time=cfg.lambda_time,
            lambda_polarity=cfg.lambda_polarity,
            lambda_uncertainty=cfg.lambda_uncertainty,
        )
        self.graph_reasoner = SignedEvidenceGraphReasoner(cfg.d_model, n_layers=cfg.graph_layers, dropout=cfg.dropout)
        self.ordinal_head = OrdinalDistributionHead(cfg.d_model, dropout=cfg.dropout)

        self.uni_t = RegressionHead(cfg.d_model, dropout=cfg.dropout)
        self.uni_a = RegressionHead(cfg.d_model, dropout=cfg.dropout)
        self.uni_v = RegressionHead(cfg.d_model, dropout=cfg.dropout)

        self.loss_fn = CDEGLoss(cfg)

    def _text_mask_from_input(self, text: torch.Tensor, text_mask: Optional[torch.Tensor]) -> torch.Tensor:
        if text_mask is not None:
            return build_sequence_mask(text[:, 1, :] if self.use_bert else text, text_mask)
        if self.use_bert:
            return build_sequence_mask(text[:, 1, :])
        return build_sequence_mask(text)

    def _encode_modalities(
        self,
        text: torch.Tensor,
        audio: torch.Tensor,
        video: torch.Tensor,
        text_mask: torch.Tensor,
        audio_mask: torch.Tensor,
        video_mask: torch.Tensor,
    ) -> Tuple[torch.Tensor, torch.Tensor, torch.Tensor]:
        t = self.bert(text) if self.use_bert else text

        ht = self.stem_t(t) + self.mod_embed[0]
        ha = self.stem_a(audio) + self.mod_embed[1]
        hv = self.stem_v(video) + self.mod_embed[2]

        ht = self.shared_encoder(ht, text_mask)
        ha = self.shared_encoder(ha, audio_mask)
        hv = self.shared_encoder(hv, video_mask)

        ht = ht + self.adapter_t(ht)
        ha = ha + self.adapter_a(ha)
        hv = hv + self.adapter_v(hv)

        ht = ht * text_mask.unsqueeze(-1).to(ht.dtype)
        ha = ha * audio_mask.unsqueeze(-1).to(ha.dtype)
        hv = hv * video_mask.unsqueeze(-1).to(hv.dtype)
        return ht, ha, hv

    @staticmethod
    def _evidence_pool(ev: Dict[str, torch.Tensor]) -> torch.Tensor:
        w = ev["slot_weight"].unsqueeze(-1)
        return (w * ev["sentiment_evidence"]).sum(dim=1)

    @staticmethod
    def _prefix_evidence(prefix: str, ev: Dict[str, torch.Tensor]) -> Dict[str, torch.Tensor]:
        keys = [
            "evidence", "raw_evidence", "sentiment_evidence", "private_evidence", "noise_evidence",
            "reconstructed_evidence", "factor_gate", "slot_gate", "slot_gate_prob", "slot_gate_logits",
            "slot_weight", "polarity", "strength", "uncertainty", "reliability", "tau", "attn", "slot_sim",
        ]
        return {f"{prefix}_{k}": ev[k] for k in keys}

    def _node_counterfactual_target(
        self,
        graph_out: Dict[str, torch.Tensor],
        factual_pred: torch.Tensor,
    ) -> torch.Tensor:
        """Compute node-level counterfactual target by removing each evidence node from pooling.

        This keeps graph message passing fixed for efficiency and recomputes only graph pooling
        and the ordinal head for each node intervention.
        """
        h = graph_out["node_hidden"]
        edge_role_prob = graph_out["edge_role_prob"]
        node_gate = graph_out["node_gate"]
        B, N, _ = h.shape
        deltas = []
        for idx in range(N):
            cf_gate = node_gate.clone()
            cf_gate[:, idx] = 0.0
            cf_repr, _ = self.graph_reasoner.pool_graph(h, edge_role_prob, cf_gate)
            cf_pred = self.ordinal_head(cf_repr)["output_logit"]
            deltas.append((factual_pred - cf_pred).abs())
        delta = torch.cat(deltas, dim=-1)  # [B, N]
        target = F.softmax(delta / 0.5, dim=-1)
        target = target * node_gate
        return target / target.sum(dim=-1, keepdim=True).clamp_min(1e-6)

    def forward(
        self,
        text: torch.Tensor,
        audio: torch.Tensor,
        video: torch.Tensor,
        text_mask: Optional[torch.Tensor] = None,
        audio_mask: Optional[torch.Tensor] = None,
        video_mask: Optional[torch.Tensor] = None,
        labels: Optional[torch.Tensor] = None,
    ) -> Dict[str, torch.Tensor]:
        text_mask = self._text_mask_from_input(text, text_mask)
        audio_mask = build_sequence_mask(audio, audio_mask)
        video_mask = build_sequence_mask(video, video_mask)

        ht, ha, hv = self._encode_modalities(text, audio, video, text_mask, audio_mask, video_mask)

        text_ev = self.evidence_t(ht, text_mask, modality_id=0)
        audio_ev = self.evidence_a(ha, audio_mask, modality_id=1)
        video_ev = self.evidence_v(hv, video_mask, modality_id=2)

        graph = self.graph_builder(text_ev, audio_ev, video_ev)
        graph_out = self.graph_reasoner(graph)
        main_out = self.ordinal_head(graph_out["graph_repr"])

        pooled_t = self._evidence_pool(text_ev)
        pooled_a = self._evidence_pool(audio_ev)
        pooled_v = self._evidence_pool(video_ev)
        logit_t = self.uni_t(pooled_t)
        logit_a = self.uni_a(pooled_a)
        logit_v = self.uni_v(pooled_v)

        node_mask = graph_out["node_gate"] > 1e-6
        if self.cfg.compute_node_cf:
            node_cf_target = self._node_counterfactual_target(graph_out, main_out["output_logit"]).detach()
        else:
            node_cf_target = graph_out["node_importance"].detach()

        output = {
            **main_out,
            "interval_width": main_out["predictive_variance"].clamp_min(1e-8).sqrt(),
            "graph_repr": graph_out["graph_repr"],
            "node_hidden": graph_out["node_hidden"],
            "z_consensus": graph_out["z_consensus"],
            "z_conflict": graph_out["z_conflict"],
            "z_compensation": graph_out["z_compensation"],
            "role_node_weight": graph_out["role_node_weight"],
            "node_importance": graph_out["node_importance"],
            "node_cf_target": node_cf_target,
            "node_mask": node_mask,
            "edge_logits": graph_out["edge_logits"],
            "edge_role_prob": graph_out["edge_role_prob"],
            "edge_importance": graph_out["edge_importance"],
            "edge_cf_target": graph_out["edge_cf_target"].detach(),
            "edge_mask": graph_out["edge_mask"] > 1e-6,
            "edge_pseudo_target": graph_out["edge_pseudo_target"],
            "sim": graph_out["sim"],
            "polarity_nodes": graph_out["polarity"],
            "uncertainty_nodes": graph_out["uncertainty"],
            "modality_ids": graph_out["modality_ids"],
            "logit_t": logit_t,
            "logit_a": logit_a,
            "logit_v": logit_v,
            **self._prefix_evidence("text", text_ev),
            **self._prefix_evidence("audio", audio_ev),
            **self._prefix_evidence("video", video_ev),
        }

        if labels is not None:
            output["losses"] = self.loss_fn(output, labels)

        return output


