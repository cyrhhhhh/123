class CDEGLoss(nn.Module):
    def __init__(self, cfg: CDEGConfig, anchors: Sequence[float] = ORDINAL_ANCHORS):
        super().__init__()
        self.cfg = cfg
        self.register_buffer("anchors", torch.tensor(anchors).float())
        self.l1 = nn.L1Loss()

    @staticmethod
    def _labels(labels: torch.Tensor) -> torch.Tensor:
        return labels.view(-1, 1).float()

    def soft_ordinal_target(self, labels: torch.Tensor) -> torch.Tensor:
        labels = self._labels(labels).to(self.anchors.device)
        anchors = self.anchors.view(1, -1)
        dist = torch.exp(-((labels - anchors) ** 2) / 2.0)
        return dist / dist.sum(dim=-1, keepdim=True).clamp_min(1e-6)

    def ordinal_loss(self, logits: torch.Tensor, labels: torch.Tensor) -> torch.Tensor:
        target = self.soft_ordinal_target(labels).to(logits.device)
        return -(target * F.log_softmax(logits, dim=-1)).sum(dim=-1).mean()

    @staticmethod
    def _orthogonality_loss(a: torch.Tensor, b: torch.Tensor) -> torch.Tensor:
        a = F.normalize(a, dim=-1, eps=1e-6)
        b = F.normalize(b, dim=-1, eps=1e-6)
        return (a * b).sum(dim=-1).pow(2).mean()

    def disentangle_regularization(self, out: Dict[str, torch.Tensor]) -> torch.Tensor:
        terms = []
        for key in ("text", "audio", "video"):
            raw = out[f"{key}_raw_evidence"]
            z_sent = out[f"{key}_sentiment_evidence"]
            z_priv = out[f"{key}_private_evidence"]
            z_noise = out[f"{key}_noise_evidence"]
            recon = out[f"{key}_reconstructed_evidence"]
            factor_gate = out[f"{key}_factor_gate"]
            uncertainty = out[f"{key}_uncertainty"]

            recon_loss = F.mse_loss(recon, raw.detach())
            orth_loss = (
                self._orthogonality_loss(z_sent, z_priv)
                + self._orthogonality_loss(z_sent, z_noise)
                + self._orthogonality_loss(z_priv, z_noise)
            ) / 3.0

            noise_gate = factor_gate[..., 2]
            unc_target = uncertainty / uncertainty.mean(dim=-1, keepdim=True).clamp_min(1e-6)
            unc_target = unc_target / unc_target.max(dim=-1, keepdim=True).values.clamp_min(1e-6)
            noise_align = F.mse_loss(noise_gate, unc_target.detach())

            # Encourage sentiment branch to be selected when slot reliability is high.
            sent_gate = factor_gate[..., 0]
            reliability = out[f"{key}_reliability"].detach()
            rel_target = F.softmax(reliability, dim=-1)
            sent_align = F.mse_loss(sent_gate, rel_target)

            terms.append(recon_loss + orth_loss + 0.5 * noise_align + 0.2 * sent_align)
        return sum(terms) / len(terms)

    def sparse_regularization(self, out: Dict[str, torch.Tensor]) -> torch.Tensor:
        terms = []
        for key in ("text", "audio", "video"):
            attn = out[f"{key}_attn"]
            gate_prob = out[f"{key}_slot_gate_prob"]
            slot_sim = out[f"{key}_slot_sim"]
            slot_weight = out[f"{key}_slot_weight"]

            attn_entropy = entropy(attn, dim=-1).mean()
            slot_entropy = entropy(slot_weight, dim=-1).mean()
            gate_l0 = gate_prob.mean()
            diversity = offdiag_mean_square(slot_sim)
            terms.append(attn_entropy + 0.5 * slot_entropy + 0.5 * gate_l0 + 0.5 * diversity)
        return sum(terms) / len(terms)

    def graph_structure_loss(self, out: Dict[str, torch.Tensor]) -> torch.Tensor:
        logits = out["edge_logits"]  # [B,N,N,3]
        target = out["edge_pseudo_target"]  # [B,N,N]
        mask = out["edge_mask"].to(logits.dtype)
        ce = F.cross_entropy(logits.permute(0, 3, 1, 2), target, reduction="none")
        return (ce * mask).sum() / mask.sum().clamp_min(1.0)

    def counterfactual_node_loss(self, out: Dict[str, torch.Tensor]) -> torch.Tensor:
        return masked_kl_div(out["node_importance"], out["node_cf_target"], out["node_mask"])

    def counterfactual_edge_loss(self, out: Dict[str, torch.Tensor]) -> torch.Tensor:
        B, N, _ = out["edge_importance"].shape
        pred = out["edge_importance"].view(B, -1)
        target = out["edge_cf_target"].view(B, -1)
        mask = out["edge_mask"].view(B, -1)
        return masked_kl_div(pred, target, mask)

    def uncertainty_calibration_loss(self, out: Dict[str, torch.Tensor], labels: torch.Tensor) -> torch.Tensor:
        labels = self._labels(labels).to(out["output_logit"].device)
        err2 = (out["output_logit"] - labels).pow(2).detach()
        return self.l1(out["predictive_variance"], err2)

    def forward(self, out: Dict[str, torch.Tensor], labels: torch.Tensor) -> Dict[str, torch.Tensor]:
        labels = self._labels(labels).to(out["output_logit"].device)
        losses = {}
        losses["main_loss"] = self.l1(out["output_logit"], labels)
        losses["ordinal_loss"] = self.ordinal_loss(out["ordinal_logits"], labels)
        losses["unimodal_loss"] = (
            self.l1(out["logit_t"], labels)
            + self.l1(out["logit_a"], labels)
            + self.l1(out["logit_v"], labels)
        ) / 3.0
        losses["disentangle_loss"] = self.disentangle_regularization(out)
        losses["sparse_loss"] = self.sparse_regularization(out)
        losses["graph_loss"] = self.graph_structure_loss(out)
        losses["cf_node_loss"] = self.counterfactual_node_loss(out)
        losses["cf_edge_loss"] = self.counterfactual_edge_loss(out)
        losses["uncertainty_loss"] = self.uncertainty_calibration_loss(out, labels)
        losses["variance_loss"] = losses["uncertainty_loss"]  # backward-compatible alias

        cfg = self.cfg
        losses["total_loss"] = (
            cfg.w_main * losses["main_loss"]
            + cfg.w_ord * losses["ordinal_loss"]
            + cfg.w_uni * losses["unimodal_loss"]
            + cfg.w_disentangle * losses["disentangle_loss"]
            + cfg.w_sparse * losses["sparse_loss"]
            + cfg.w_graph * losses["graph_loss"]
            + cfg.w_cf_node * losses["cf_node_loss"]
            + cfg.w_cf_edge * losses["cf_edge_loss"]
            + cfg.w_unc * losses["uncertainty_loss"]
        )
        return losses


